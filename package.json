{
	"name": "whisper-cal",
	"version": "0.6.1",
	"description": "WhisperCal Obsidian plugin",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"calendar",
		"microsoft-365",
		"outlook",
		"meeting-notes",
		"macwhisper",
		"transcription",
		"speaker-tagging",
		"llm"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@types/node": "^18.0.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"eslint": "^9.30.0",
		"obsidian": "~1.10.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	}
}
